<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".CreditFragment">

      <LinearLayout
          android:layout_marginTop="@dimen/_50sdp"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:background="@color/white"
          android:orientation="vertical">
          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginStart="@dimen/_10sdp"
              android:orientation="horizontal">
              <ImageView
                  android:id="@+id/backk"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_gravity="center"
                  android:src="@drawable/baseline_arrow_back_24"/>

              <com.google.android.material.textview.MaterialTextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:textColor="@color/black"
                  android:textStyle="bold"
                  android:layout_gravity="center"
                  android:textSize="@dimen/_20ssp"
                  android:text="   Credit Report"/>
          </LinearLayout>

          <com.google.android.material.textview.MaterialTextView
              android:layout_marginTop="@dimen/_30sdp"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginStart="@dimen/_10ssp"
              android:textSize="@dimen/_25ssp"
              android:textColor="@color/black"
              android:textStyle="bold"
              android:text="CREDIT"/>

          <com.google.android.material.textview.MaterialTextView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginStart="@dimen/_10ssp"
              android:text="Score builder service"/>


          <com.google.android.material.textview.MaterialTextView
              android:layout_width="wrap_content"
              android:textSize="@dimen/_15ssp"

              android:layout_marginTop="@dimen/_20sdp"
              android:textStyle="bold"
              android:layout_height="wrap_content" android:layout_marginStart="@dimen/_10ssp"
              android:text="Building a Credit Score can help you get..."/>

          <LinearLayout
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:orientation="vertical">
              <HorizontalScrollView
                  android:layout_marginTop="@dimen/_10sdp"
                  android:id="@+id/creditScrollView"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:scrollbars="none">

                  <LinearLayout
                      android:id="@+id/imageContainer"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:orientation="horizontal"
                      android:padding="16dp">

                      <LinearLayout
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:orientation="vertical">

                          <androidx.cardview.widget.CardView
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:layout_marginEnd="16dp"
                              app:cardCornerRadius="@dimen/_8sdp"
                              app:cardElevation="@dimen/_4sdp"
                              android:layout_marginBottom="26dp">

                              <LinearLayout
                                  android:layout_width="wrap_content"
                                  android:layout_height="wrap_content"
                                  android:orientation="vertical"
                                  android:padding="8dp">

                                  <ImageView
                                      android:layout_width="200dp"
                                      android:layout_height="200dp"
                                      android:src="@drawable/imageonew"/>

                                  <TextView

                                      android:layout_width="wrap_content"
                                      android:layout_height="wrap_content"
                                      android:textStyle="bold"
                                      android:textSize="@dimen/_13ssp"
                                      android:textColor="@color/black"
                                      android:text="Better Chances Rates on Loans"/>

                                  <TextView
                                      android:layout_marginTop="@dimen/_20sdp"
                                      android:layout_width="wrap_content"
                                      android:layout_height="wrap_content"
                                      android:text="as high credit score \nreflects strong reapayment \nhistory of customer"/>
                              </LinearLayout>
                          </androidx.cardview.widget.CardView>

                      </LinearLayout>


                      <LinearLayout
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:orientation="vertical">
                          <androidx.cardview.widget.CardView
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:layout_marginEnd="16dp"
                              app:cardCornerRadius="@dimen/_8sdp"
                              app:cardElevation="@dimen/_4sdp"
                              android:layout_marginBottom="16dp">

                              <LinearLayout
                                  android:layout_width="wrap_content"
                                  android:layout_height="wrap_content"
                                  android:orientation="vertical"
                                  android:padding="8dp">

                                  <ImageView
                                      android:layout_width="200dp"
                                      android:layout_height="200dp"
                                      android:src="@drawable/imagetwo"/>

                                  <TextView
                                      android:layout_width="wrap_content"
                                      android:layout_height="wrap_content"
                                      android:textStyle="bold"
                                      android:textSize="@dimen/_13ssp"
                                      android:textColor="@color/black"
                                      android:text="Better Chances Rates on Loans"/>

                                  <TextView
                                      android:layout_width="wrap_content"
                                      android:layout_height="wrap_content"
                                      android:layout_marginTop="@dimen/_20sdp"
                                      android:text="as high credit score \nreflects strong reapayment \nhistory of customer"/>
                              </LinearLayout>
                          </androidx.cardview.widget.CardView>

                      </LinearLayout>

                      <LinearLayout
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:orientation="vertical">
                          <androidx.cardview.widget.CardView
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:layout_marginEnd="16dp"
                              app:cardCornerRadius="@dimen/_8sdp"
                              app:cardElevation="@dimen/_4sdp"
                              android:layout_marginBottom="16dp">

                              <LinearLayout
                                  android:layout_width="wrap_content"
                                  android:layout_height="wrap_content"
                                  android:orientation="vertical"
                                  android:padding="8dp">

                                  <ImageView
                                      android:layout_width="200dp"
                                      android:layout_height="200dp"
                                      android:src="@drawable/three"/>

                                  <TextView
                                      android:layout_width="wrap_content"
                                      android:layout_height="wrap_content"
                                      android:textStyle="bold"
                                      android:textSize="@dimen/_13ssp"
                                      android:textColor="@color/black"
                                      android:text="Better Chances Rates on Loans"/>

                                  <TextView
                                      android:layout_width="wrap_content"
                                      android:layout_height="wrap_content"
                                      android:layout_marginTop="@dimen/_20sdp"
                                      android:text="as high credit score \nreflects strong reapayment \nhistory of customer"/>
                              </LinearLayout>
                          </androidx.cardview.widget.CardView>
                      </LinearLayout>

                      <LinearLayout
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:orientation="vertical">
                          <androidx.cardview.widget.CardView
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:layout_marginEnd="16dp"
                              app:cardCornerRadius="@dimen/_8sdp"
                              app:cardElevation="@dimen/_4sdp"
                              android:layout_marginBottom="16dp">

                              <LinearLayout
                                  android:layout_width="wrap_content"
                                  android:layout_height="wrap_content"
                                  android:orientation="vertical"
                                  android:padding="8dp">

                                  <ImageView
                                      android:layout_width="200dp"
                                      android:layout_height="200dp"
                                      android:src="@drawable/four"/>

                                  <TextView
                                      android:layout_width="wrap_content"
                                      android:layout_height="wrap_content"
                                      android:textStyle="bold"
                                      android:textSize="@dimen/_13ssp"
                                      android:textColor="@color/black"
                                      android:text="Better Chances Rates on Loans"/>

                                  <TextView
                                      android:layout_width="wrap_content"
                                      android:layout_height="wrap_content"
                                      android:layout_marginTop="@dimen/_20sdp"
                                      android:text="as high credit score \nreflects strong reapayment \nhistory of customer "/>
                              </LinearLayout>
                          </androidx.cardview.widget.CardView>
                      </LinearLayout>

                  </LinearLayout>
              </HorizontalScrollView>
          </LinearLayout>
      </LinearLayout>
</FrameLayout>